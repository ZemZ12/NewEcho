rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public profile: username only, no phone number (Firebase Auth already
    // owns that, and it's never written here). Readable by any signed-in
    // user so group members/search can resolve usernames; writable only by
    // the owner, once, at account creation. Usernames are immutable for now
    // — changing one would need to release the old usernames/{lower} doc
    // too, which isn't implemented yet.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['username', 'usernameLower', 'createdAt'])
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 3
        && request.resource.data.username.size() <= 20
        && request.resource.data.usernameLower == request.resource.data.username.lower();
      allow update, delete: if false;
    }

    // Reservation lock keyed by lowercased username, doc id enforces global
    // uniqueness via Firestore's create-only-if-absent semantics.
    match /usernames/{usernameLower} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
