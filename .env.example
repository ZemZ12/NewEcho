# Copy to .env and fill in once the Firebase and Stream Chat projects exist (see plan M0/M1).
# EXPO_PUBLIC_ vars are inlined into the client bundle — fine for these (they're public client keys),
# never put server-only secrets (e.g. Stream's API secret used for token minting) behind this prefix.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

EXPO_PUBLIC_STREAM_API_KEY=
