# Copy to .env and fill in once the Stream Chat project exists.
# EXPO_PUBLIC_ vars are inlined into the client bundle — fine for this one (it's a public client key).
# The Stream API *secret* used for token minting lives only in the Cloud Functions secret manager
# (functions/src/index.ts), never here.
#
# Firebase itself needs no env vars: native @react-native-firebase auto-configures from
# google-services.json / GoogleService-Info.plist.

EXPO_PUBLIC_STREAM_API_KEY=
